# Google Apps Script Web App URL
# Copy this file to .env and fill in your deployment ID.
# The .env file is gitignored — never commit the actual URL.
#
# How to find your deployment ID:
#   Apps Script → Deploy → Manage Deployments → copy the /exec URL
#
# For GitHub Pages CI/CD:
#   Add VITE_GAS_URL as a repository secret in Settings → Secrets → Actions
#   Then inject it in .github/workflows/deploy.yml:
#     env:
#       VITE_GAS_URL: ${{ secrets.VITE_GAS_URL }}

VITE_GAS_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
